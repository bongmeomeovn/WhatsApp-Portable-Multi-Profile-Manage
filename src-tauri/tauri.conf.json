{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WhatsApp Portable",
  "version": "1.0.0",
  "identifier": "com.portable.whatsapp",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "WhatsApp Portable — Profiles",
        "width": 720,
        "height": 520,
        "minWidth": 500,
        "minHeight": 400,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
